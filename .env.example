# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env   (or copy it in your editor)
# `.env` is gitignored — never commit real keys.

# --- Required ---
# Used for OpenAI embeddings (retriever_setup.py) and the gpt-4o chat model (llms/openai.py).
# Without this the app crashes on startup.
OPENAI_API_KEY=

# --- Required for the web-search route ---
# Used by the web_search graph node (Tavily). App boots without it, but
# queries classified as "search" will fail.
TAVILY_API_KEY=

# --- Optional / currently unused by the running code ---
# The active vector store is in-memory FAISS; Qdrant is commented out in
# retriever_setup.py. These are only needed if you re-enable Qdrant.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_CODE_COLLECTION=code_documents
QDRANT_DOCS_COLLECTION=documents

# --- MongoDB (note) ---
# The Mongo connection is HARDCODED to mongodb://localhost:27017 / db "adaptive_rag"
# in src/db/mongo_client.py, so these vars are NOT read by the code today.
# Just make sure a MongoDB server is running on localhost:27017 for /rag/query.
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB_NAME=adaptive_rag
