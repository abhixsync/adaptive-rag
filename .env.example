# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env   (or copy it in your editor)
# `.env` is gitignored — never commit real keys.

# --- Required ---
# Used for OpenAI embeddings (retriever_setup.py) and the gpt-4o chat model (llms/openai.py).
# Without this the app crashes on startup.
OPENAI_API_KEY=

# --- Required for the web-search route ---
# Used by the web_search graph node (Tavily). App boots without it, but
# queries classified as "search" will fail.
TAVILY_API_KEY=

# --- Vector store (Qdrant) ---
# Per-user document embeddings are persisted in Qdrant. Run it locally with:
#   docker run -d -p 6333:6333 -v qdrant_storage:/qdrant/storage qdrant/qdrant
# Local Qdrant needs no API key. QDRANT_URL defaults to localhost:6333 if unset.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_USER_DOCS_COLLECTION=user_documents

# --- Auth (JWT) ---
# Secret used to sign login tokens. CHANGE THIS to a long random string.
# Defaults to an insecure dev value if unset.
JWT_SECRET=
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# --- MongoDB (note) ---
# The Mongo connection is HARDCODED to mongodb://localhost:27017 / db "adaptive_rag"
# in src/db/mongo_client.py. Make sure MongoDB is running on localhost:27017.
# It stores users, chat history, and the per-user document registry.
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB_NAME=adaptive_rag
